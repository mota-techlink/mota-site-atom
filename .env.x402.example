# ─── X402 Protocol Configuration ────────────────────────
# Required for X402 payment endpoints

# Your wallet address to receive payments (REQUIRED)
X402_RECEIVER_ADDRESS=0xYourWalletAddressHere

# Facilitator URL (optional, defaults to Coinbase's public facilitator)
# X402_FACILITATOR_URL=https://x402-facilitator.cdp.coinbase.com

# Blockchain network (optional, defaults to "base-sepolia" for testing)
# Use "base" for production
# X402_NETWORK=base-sepolia

# Token contract address (optional, defaults to USDC on the selected network)
# Base Sepolia USDC: 0x036CbD53842c5426634e7929541eC2318f3dCF7e
# Base Mainnet USDC: 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# X402_TOKEN_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
