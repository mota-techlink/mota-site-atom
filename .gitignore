# ==============================================
# Dependencies (依赖包)
# ==============================================
node_modules/
.pnpm-store
.npm/

# ==============================================
# Next.js & React Build Output (构建产物)
# ==============================================
.next/
out/
build/
dist/
.vercel/

# ==============================================
# Environment Variables (🔒 绝对核心：环境变量)
# 必须忽略，防止 API Key 泄露！
# ==============================================
.env
.env*.local
.env.development
.env.test
.env.production
.dev.vars
# 允许提交示例文件，方便社区开发者参考
!.env.example

# ==============================================
# Cloudflare Pages / Workers
# ==============================================
.wrangler/
.cargo-ok

# ==============================================
# Supabase (Local Dev)
# ==============================================
# 忽略本地分支配置和临时文件
supabase/.branches
supabase/.temp
supabase/config.toml
supabase/snippets/
# 注意：supabase/migrations 和 config.toml 应该被提交，所以不要忽略它们

# ==============================================
# Python / Data Pipeline (你的数据处理部分)
# ==============================================
# Python 缓存
__pycache__/
*.py[cod]
*$py.class

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# 虚拟环境 (Conda / Venv)
venv/
.venv/
env/
# 忽略你在截图里创建的 conda 目录
dh_pipeline/

# ==============================================
# OS & IDE System Files (系统垃圾文件)
# ==============================================
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ==============================================
# Logs & Debug
# ==============================================
npm-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ==============================================
# Testing
# ==============================================
/coverage/

# ==============================================
# TypeScript
# ==============================================
*.tsbuildinfo
next-env.d.ts
# 注意：next-env.d.ts 通常建议提交，但如果你想保持仓库极其干净也可以忽略，
# 它是 Next.js 自动生成的。一般保留在 Git 中比较好，这里我不列入忽略。

# Generated Files
src/generated/
public/search.json
public/sitemap.xml
ChatMD/
.cache/

# ==============================================
# Refer Docs
# ==============================================
refer-docs/